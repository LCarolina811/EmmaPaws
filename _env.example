# EmmaPaws — Variables de entorno
# Copia este archivo como ".env" y ajusta los valores si es necesario.

# URL del API Gateway (el frontend se conecta a esta dirección)
API_GATEWAY_URL=http://api-gateway:8000

# Servicio de Autenticación (MongoDB)
AUTH_SERVICE_URL=http://auth-service:8001
AUTH_DATABASE_URL=mongodb://auth-db:27017/auth_db

# Servicio de Catálogo de Productos (PostgreSQL)
CATALOG_SERVICE_URL=http://catalog-service:8002
CATALOG_DATABASE_URL=postgresql://user:password@catalog-db:5432/catalog_db

# Servicio de Órdenes de Compra (MongoDB)
ORDERS_SERVICE_URL=http://orders-service:8003
ORDERS_DATABASE_URL=mongodb://orders-db:27017/orders_db

# Servicio de Reseñas de Productos (PostgreSQL)
REVIEWS_SERVICE_URL=http://reviews-service:8004
REVIEWS_DATABASE_URL=postgresql://user:password@reviews-db:5432/reviews_db
